{
  "name": "agent-workflow",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Docs-first agent workflow toolkit — generators, doc-linter, templates. Consumers install as devDependencies; scaffolds copy into --target from package templates.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doc-lint": "node node_modules/@agent-workflow/doc-linter/src/cli.ts",
    "gen:scaffold-docs": "node node_modules/@agent-workflow/generators/src/scaffold-docs-structure.ts",
    "gen:create-adr": "node node_modules/@agent-workflow/generators/src/create-adr.ts",
    "gen:diary-entry": "node node_modules/@agent-workflow/generators/src/add-diary-entry.ts",
    "gen:create-feature-spec": "node node_modules/@agent-workflow/generators/src/create-feature-spec.ts",
    "gen:create-incident-report": "node node_modules/@agent-workflow/generators/src/create-incident-report.ts",
    "gen:create-postmortem": "node node_modules/@agent-workflow/generators/src/create-postmortem.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@agent-workflow/doc-linter": "workspace:*",
    "@agent-workflow/generators": "workspace:*",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
