{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workflow.dev/schemas/doc-front-matter.json",
  "title": "Agent framework doc front-matter",
  "description": "Schema for the YAML front-matter on every doc under docs/ (and AGENTS.md). The `type` field is the discriminator that selects the required fields. See docs/specs/agent-workflow.md §4 (AF-7). Markdown *style* is owned by Prettier (ADR-0009); this schema validates *structure/metadata* only.",
  "type": "object",
  "required": ["title", "type"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "type": {
      "enum": [
        "adr",
        "spec",
        "diary",
        "guide",
        "index",
        "requirements",
        "architecture",
        "backlog",
        "todo",
        "feature-spec"
      ]
    },
    "status": { "type": "string" },
    "updated": { "type": "string", "format": "date" },
    "date": { "type": "string", "format": "date" },
    "id": { "type": "string", "pattern": "^ADR-[0-9]{4}$" },
    "deciders": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "supersedes": {
      "anyOf": [{ "type": "null" }, { "type": "string", "pattern": "^ADR-[0-9]{4}$" }]
    },
    "superseded_by": {
      "anyOf": [{ "type": "null" }, { "type": "string", "pattern": "^ADR-[0-9]{4}$" }]
    },
    "scope": { "type": "string", "minLength": 1 },
    "motivated_by": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ADR-[0-9]{4}$" }
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2} \\(.+\\)$"
    },
    "summary": { "type": "string", "minLength": 1 },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "backlog_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*-[0-9]+$" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "adr" } }, "required": ["type"] },
      "then": {
        "required": [
          "id",
          "title",
          "type",
          "status",
          "date",
          "deciders",
          "supersedes",
          "superseded_by"
        ],
        "properties": {
          "status": { "enum": ["Proposed", "Accepted", "Superseded", "Deprecated"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "spec" } }, "required": ["type"] },
      "then": {
        "required": ["title", "type", "status", "scope", "motivated_by", "updated"],
        "properties": {
          "status": { "enum": ["Draft", "Active", "Superseded"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "diary" } }, "required": ["type"] },
      "then": {
        "required": ["title", "type", "timestamp", "summary", "keywords"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "feature-spec" } }, "required": ["type"] },
      "then": {
        "required": ["title", "type", "updated", "backlog_ids", "status"],
        "properties": {
          "status": { "enum": ["Draft", "Active", "Completed", "Superseded"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["guide", "index", "requirements", "architecture", "backlog", "todo"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["title", "type", "updated"],
        "properties": {
          "status": { "const": "living" }
        }
      }
    }
  ]
}
