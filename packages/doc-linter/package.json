{
  "name": "@agent-workflow/doc-linter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Validates doc front-matter against the JSON Schema and keeps the ADR index in sync.",
  "bin": {
    "doc-lint": "./src/cli.ts"
  },
  "scripts": {
    "doc-lint": "node src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.8.1"
  }
}
